const int fanPin = 6;        // Fan control pin
const int currentPin = A0;   // ACS712 OUT pin

float sensitivity = 0.066;   // Sensitivity for ACS712 30A (use 0.100 for 20A, 0.185 for 5A)
float overcurrentThreshold = 0.8; // Amps – tweak based on your fan's max draw

void setup() {
  Serial.begin(9600);
  pinMode(fanPin, OUTPUT);
}

void loop() {
  // Read analog voltage
  int adcValue = analogRead(currentPin);
  float voltage = (adcValue * 5.0) / 1023.0;
  float current = (voltage - 2.5) / sensitivity;

  // Print values
  Serial.print("Voltage: ");
  Serial.print(voltage, 3);
  Serial.print(" V | Current: ");
  Serial.print(current, 3);
  Serial.println(" A");

  // Overcurrent protection
  if (current > overcurrentThreshold) {
    Serial.println("⚠️ Overcurrent! Turning fan OFF.");
    digitalWrite(fanPin, LOW);
  } else {
    digitalWrite(fanPin, HIGH);
  }

  delay(500);
}
